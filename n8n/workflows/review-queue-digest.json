{
  "name": "review-queue-digest",
  "nodes": [
    {
      "parameters": {
        "rule": {"interval": [{"field": "hours", "hoursInterval": 6}]}
      },
      "id": "Schedule_Digest",
      "name": "Every 6 Hours",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [260, 260]
    },
    {
      "parameters": {
        "url": "={{$env.LMS_API_BASE_URL}}/lms/dashboard",
        "method": "GET",
        "sendHeaders": true,
        "headerParameters": {"parameters": [{"name": "Authorization", "value": "Bearer change-me"}]}
      },
      "id": "Http_Dashboard",
      "name": "Fetch Dashboard",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [520, 260]
    }
  ],
  "connections": {
    "Every 6 Hours": {
      "main": [[{"node": "Fetch Dashboard", "type": "main", "index": 0}]]
    }
  }
}
